{
  "manifest_version": 3,
  "name": "ContextHub Demo Sidebar",
  "version": "0.0.1",
  "description": "Visual-only ContextHub extension demo for Claude.ai.",
  "key": "",
  "permissions": ["storage", "tabs", "activeTab", "identity"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://www.claude.ai/*",
    "https://chatgpt.com/*",
    "https://www.chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.supabase.co/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://www.claude.ai/*",
        "https://chatgpt.com/*",
        "https://www.chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "assets/*"],
      "matches": [
        "https://claude.ai/*",
        "https://www.claude.ai/*",
        "https://chatgpt.com/*",
        "https://www.chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "ContextHub Demo"
  }
}
