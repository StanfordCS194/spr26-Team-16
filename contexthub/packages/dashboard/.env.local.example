# Supabase project credentials. Copy this file to `.env.local` and fill in the values.
# Required for the dashboard's auth UI to render the "Sign in with Google" button.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth must be enabled in the Supabase dashboard under Authentication -> Providers -> Google.
# Configure the Google client ID/secret there; the dashboard does not need them directly.
