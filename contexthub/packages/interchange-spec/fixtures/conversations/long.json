  "messages": [
    { "role": "user", "content": [{ "type": "text", "text": "Let's design a push pipeline." }], "created_at": "2026-04-17T10:30:00Z" },
    { "role": "assistant", "content": [{ "type": "text", "text": "Sure — what's the latency budget for POST /pushes?" }], "created_at": "2026-04-17T10:30:10Z" },
    { "role": "user", "content": [{ "type": "text", "text": "Under 500ms to accept." }], "created_at": "2026-04-17T10:31:00Z" },
    { "role": "assistant", "content": [{ "type": "text", "text": "Then go async: accept, enqueue, return 202. Worker runs summarization out-of-band." }], "created_at": "2026-04-17T10:31:15Z" },
    { "role": "user", "content": [{ "type": "text", "text": "What queue?" }], "created_at": "2026-04-17T10:32:00Z" },
    { "role": "assistant", "content": [{ "type": "text", "text": "ARQ on Redis. Lightweight, Python-native, good retry + DLQ semantics." }], "created_at": "2026-04-17T10:32:10Z" },
    { "role": "user", "content": [{ "type": "text", "text": "Retry strategy?" }], "created_at": "2026-04-17T10:33:00Z" },
    { "role": "assistant", "content": [{ "type": "text", "text": "Exponential backoff with jitter, max 3 retries, then DLQ. Per-job failure classification so we don't retry on 4xx from the LLM." }], "created_at": "2026-04-17T10:33:20Z" },
    { "role": "user", "content": [{ "type": "text", "text": "How does the extension know when it's done?" }], "created_at": "2026-04-17T10:34:00Z" },
    { "role": "assistant", "content": [{ "type": "text", "text": "Polls GET /pushes/{id} until status flips to ready or failed. SSE is a v1 upgrade." }], "created_at": "2026-04-17T10:34:20Z" }
  ],
