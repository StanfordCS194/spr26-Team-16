{
  "name": "contexthub",
  "version": "0.0.0",
  "private": true,
  "description": "ContextHub monorepo root — version control for LLM conversations.",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "codegen": "pnpm -r --filter @contexthub/interchange-spec run codegen",
    "test": "pnpm -r test",
    "test:py": "uv run --package contexthub-interchange pytest",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "dashboard:dev": "pnpm --filter @contexthub/dashboard dev",
    "dashboard:build": "pnpm --filter @contexthub/dashboard build",
    "dashboard:start": "pnpm --filter @contexthub/dashboard start",
    "extension:dev": "pnpm --filter @contexthub/extension dev",
    "extension:build": "pnpm --filter @contexthub/extension build"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vitest": "^2.1.1",
    "json-schema-to-typescript": "^15.0.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "@types/node": "^22.5.5",
    "prettier": "^3.3.3"
  }
}
