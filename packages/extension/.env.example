# Copy this file to `.env` and fill in the values, then rebuild the extension
# (`pnpm extension:build`). See docs/SETUP.md for where to find each value.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase project "anon"/publishable key (Project Settings -> API).
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Where the backend API is reachable. Defaults to http://localhost:8765 if unset.
VITE_API_BASE_URL=http://localhost:8765
