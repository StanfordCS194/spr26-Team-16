# Backend environment template. Copy to backend/.env and fill in real values.
# The real backend/.env is gitignored — never commit it. See docs/SETUP.md §5.

# --- Supabase (REPLACE the placeholders) ---
# 1. DATABASE_URL: Supabase project → Settings → Database → "Connection string" → URI tab.
#    Use the SESSION POOLER (port 5432). Replace [YOUR-PASSWORD] with your DB password,
#    then change the prefix from `postgresql://` to `postgresql+psycopg://`.
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:5432/postgres

# 2. SUPABASE_JWT_SECRET: legacy HS256 secret. Modern Supabase projects use asymmetric
#    (ES256/RS256) JWTs verified via the JWKS endpoint, resolved automatically from
#    SUPABASE_URL below. Only used as a fallback for HS256 tokens (tests / legacy).
SUPABASE_JWT_SECRET=unused-for-asymmetric-projects

# 3. SUPABASE_URL: your project URL.
SUPABASE_URL=https://<project-ref>.supabase.co

# 4. SUPABASE_SERVICE_KEY: Settings → API → "service_role" key (NOT the anon key).
#    Admin-level — keep in .env, never commit.
SUPABASE_SERVICE_KEY=<your-supabase-service-role-key>

# --- Other settings ---
# Set true ONLY for the fully-local Docker / dev-auth path (see docs/START_FROM_SCRATCH.md).
ENABLE_DEV_AUTH=false

# Empty REDIS_URL disables async job enqueue. Saves still complete; summarization is
# skipped until this points at a real Redis (e.g. Upstash or local docker).
REDIS_URL=

# OAuth client IDs the backend accepts Google ID tokens from (comma-separated;
# extension + dashboard clients).
GOOGLE_OAUTH_CLIENT_IDS=<your-google-oauth-client-id>.apps.googleusercontent.com

# --- LLM + embeddings: pick ONE provider path ---
# Option A — direct Anthropic (+ Voyage for embeddings):
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# VOYAGE_API_KEY=<your-voyage-api-key>

# Option B — Vercel AI Gateway (uncomment to use instead of Option A):
# AI_GATEWAY_API_KEY=<your-vercel-ai-gateway-key>
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# AI_GATEWAY_LLM_MODEL=deepseek/deepseek-v4-flash
# AI_GATEWAY_EMBEDDING_MODEL=voyage/voyage-3.5-lite
# AI_GATEWAY_EMBEDDING_DIMENSIONS=1024
